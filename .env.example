# Firebase config — copy this file to .env.local and fill in your values.
# .env.local is gitignored. For GitHub Pages, set these as GitHub Actions Secrets.
# NOTE: These values will be visible in the compiled JS bundle (unavoidable for
# client-side Firebase). Security is enforced by Auth + Firestore Rules, not the key.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
