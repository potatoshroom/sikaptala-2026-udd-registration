rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /registrations/{uid} {
      // Only authenticated UDD/CDD students can create a registration.
      // The document ID must equal the submitter's UID (enforced by the app, verified here).
      // No client reads, updates, or deletes — admin uses Firebase Console only.
      allow create: if isAllowedDomain()
                    && request.auth.uid == uid
                    && isValidRegistration(request.resource.data);
      allow read, update, delete: if false;
    }

  }

  function isAllowedDomain() {
    return request.auth != null
      && (request.auth.token.email.matches('.*@udd\\.edu\\.ph')
          || request.auth.token.email.matches('.*@cdd\\.edu\\.ph'));
  }

  function isValidRegistration(data) {
    return data.keys().hasAll(['uid', 'name', 'studentId', 'yearSection', 'email', 'competitions', 'submittedAt'])
      && data.uid == request.auth.uid
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 20
      && data.yearSection is string && data.yearSection.size() > 0 && data.yearSection.size() <= 30
      && data.email == request.auth.token.email
      && data.competitions is list && data.competitions.size() >= 1
      && data.submittedAt == request.time;
  }
}
