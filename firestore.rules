rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Path: competitions/{id}
    // Competition metadata managed by admins. Read by both portals; written only by admins.
    match /competitions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Path: admins/{email}
    // Seeded by the admin seed script. No client-side writes.
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Path: profiles/{uid}
    // Stores a student's locked profile details (name, student ID, year, program, block, FB).
    // Written once on first registration; never updated or deleted from the client.
    match /profiles/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid
                  && isAllowedDomain();
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && isAllowedDomain()
                    && request.resource.data.keys().hasAll(
                         ['lastName', 'firstName', 'studentId', 'yearLevel', 'program', 'block', 'facebookLink', 'createdAt'])
                    && request.resource.data.lastName is string && request.resource.data.lastName.size() > 0
                    && request.resource.data.firstName is string && request.resource.data.firstName.size() > 0
                    && request.resource.data.studentId is string && request.resource.data.studentId.size() > 0;
      // No update, no delete from client
    }

    // Path: registrations/{competitionId}/entries/{uid}
    // The document ID is the submitter's Firebase UID.
    match /registrations/{competitionId}/entries/{uid} {
      allow create: if isAllowedDomain()
                    && request.auth.uid == uid
                    && isValidEntry(request.resource.data, competitionId)
                    && !isExclusivityViolation(competitionId, uid);

      // Allow the submitter to read their own entry (for the "already registered" check).
      // Allow any authenticated UDD/CDD user to read all entries (admin portal).
      allow read: if isAllowedDomain();

      // Allow the submitter to delete (withdraw) their own registration.
      allow delete: if request.auth != null
                    && request.auth.uid == uid
                    && isAllowedDomain();

      // Allow any authenticated UDD/CDD user to update status (and optionally denialReason) only.
      // Note: no admin role exists yet — any UDD/CDD account can technically call this.
      allow update: if isAllowedDomain()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'denialReason'])
                    && request.resource.data.status in ['pending', 'approved', 'denied'];
    }

  }

  function isAdmin() {
    return request.auth != null
      && exists(/databases/(default)/documents/admins/$(request.auth.token.email));
  }

  function isAllowedDomain() {
    return request.auth != null
      && (request.auth.token.email.matches('.*@udd\\.edu\\.ph')
          || request.auth.token.email.matches('.*@cdd\\.edu\\.ph'));
  }

  // Prevents the same person from leading a team in both Game Jam and Hackathon.
  // Note: this only covers the team leader (the submitter). Member-level
  // cross-checking is enforced by the admin during manual review.
  function isExclusivityViolation(competitionId, uid) {
    return (competitionId == 'game-jam'
              && exists(/databases/(default)/documents/registrations/hackathon/entries/$(uid)))
        || (competitionId == 'hackathon'
              && exists(/databases/(default)/documents/registrations/game-jam/entries/$(uid)));
  }

  function isValidEntry(data, competitionId) {
    let hasBase = data.keys().hasAll(['uid', 'competitionId', 'submittedAt', 'status'])
      && data.uid == request.auth.uid
      && data.competitionId == competitionId
      && data.submittedAt == request.time
      && data.status == 'pending';

    // Individual entry shape
    let isIndividual = data.keys().hasAll(['name', 'studentId', 'yearLevel', 'program', 'block', 'facebookLink', 'email'])
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 11
      && data.yearLevel is string && data.yearLevel.size() > 0
      && data.program is string && data.program.size() > 0
      && data.block is string && data.block.size() > 0
      && data.facebookLink is string && data.facebookLink.size() > 0
      && data.email == request.auth.token.email;

    // Team entry shape
    let isTeam = data.keys().hasAll(['teamName', 'leader', 'members', 'totalMembers'])
      && data.teamName is string && data.teamName.size() > 0 && data.teamName.size() <= 60
      && data.leader is map
      && data.leader.email == request.auth.token.email
      && data.members is list
      && data.totalMembers is int
      && data.totalMembers >= 2
      && data.totalMembers <= 8;

    return hasBase && (isIndividual || isTeam);
  }
}
